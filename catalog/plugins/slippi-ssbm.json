{
  "id": "slippi-ssbm",
  "name": "SSBM Plugin",
  "description": "Reads live Slippi events from Dolphin.",
  "donationUrl": "https://buymeacoffee.com/fkribs",
  "repository": "https://github.com/fkribs/SaltshakerSSBMPlugin",
  "commit": "733b7461cde63e0c8a25efde58a87d3ab5350c92",
  "version": "1.0.8",
  "artifactUrl": "https://github.com/fkribs/SaltshakerPlugins/releases/download/slippi-ssbm-v1.0.8/saltshaker-plugin-slippi-ssbm-1.0.8.tgz",
  "sha256": "8aefa2cb63469cc090b74942e51c892bfbd2c402547692be6568e08fd7069e10",
  "dev": false,
  "minClientVersion": "0.2.10",
  "permissions": [
    "file.read",
    "dolphin.subscribe",
    "app.launch"
  ],
  "externalApp": {
    "label": "Launch Slippi",
    "settingKey": "slippiExePath"
  },
  "resources": [
    {
      "id": "slippiUserFile",
      "path": "{home}/AppData/Roaming/Slippi Launcher/netplay/User/Slippi/user.json",
      "macPath": "{home}/Library/Application Support/com.project-slippi.dolphin/Slippi/user.json",
      "type": "json"
    }
  ],
  "settings": [
    {
      "key": "hangupOnGameEnd",
      "type": "boolean",
      "label": "Hang up on game end",
      "description": "If enabled, Saltshaker will disconnect the call when Dolphin emits GameEnd.",
      "default": false
    },
    {
      "key": "slippiExePath",
      "type": "path",
      "label": "Slippi executable path",
      "description": "Path to the Slippi Launcher executable.",
      "winDefault": "{home}/AppData/Local/Programs/Slippi Launcher/Slippi Launcher.exe",
      "macDefault": "{home}/AppData/Local/Programs/Slippi Launcher/Slippi Launcher.exe"
    },
    {
      "key": "autoLaunchSlippi",
      "type": "boolean",
      "label": "Auto-launch Slippi when plugin runs",
      "description": "Automatically launches the Slippi executable when the plugin starts.",
      "default": false
    }
  ]
}
